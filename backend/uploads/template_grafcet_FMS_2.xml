                      <ST>
                        <xhtml xmlns="http://www.w3.org/1999/xhtml">// STEP 1

Etapa1_Ativa := TRUE;

// Ação - movimentar eixo Y para a posição Home
// Insira lógica de acionamento se necessário

IF Sensor_Y_Home THEN
	Transicao_1_2 := TRUE;
END_IF</xhtml>
                      </ST>
                    </body>
                    <addData>
                      <data name="http://www.3s-software.com/plcopenxml/objectid" handleUnknown="discard">
